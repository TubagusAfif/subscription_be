generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  OWNER
}

enum CoinOrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum CoinTransactionType {
  TOPUP
  SPEND
}

enum SubscriptionStatus {
  ACTIVE
  RENEWED
  ON_HOLD
  CANCELLED
  EXPIRED
}

enum SubscriptionEventType {
  ACTIVATED
  CANCELED
  EXPIRED
  RENEWED
  PLAN_SWITCHED
}

enum BillingCycleStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PlanSwitchType {
  UPGRADE
  DOWNGRADE
  CROSSGRADE
}

enum PlanSwitchStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id                          Int       @id @default(autoincrement())
  name                        String
  email                       String    @unique
  role                        Role      @default(OWNER)
  phone                       String?
  password_hash               String
  is_active                   Boolean   @default(true)
  activation_token            String?
  activation_token_expires_at DateTime?
  reset_token                 String?
  reset_token_expires_at      DateTime?
  created_at                  DateTime  @default(now())
  created_by                  Int?
  updated_at                  DateTime  @updatedAt
  updated_by                  Int?
  deleted_at                  DateTime?
  deleted_by                  Int?

  refresh_tokens      RefreshToken[]
  profile             UserProfile?
  coin_orders         CoinOrder[]
  wallet              CoinWallet?
  coin_transactions   CoinTransaction[]
  subscriptions       Subscription[]
  subscription_quotas SubscriptionQuota[]
  orders              Order[]
  // owned_clinics                Clinic[]
  // assigned_operational_users   OperationalUser[] @relation("AssignedBy")
  // granted_role_permissions     RolePermission[]  @relation("GrantedBy")

  @@map("users")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique
  expires_at DateTime
  is_revoked Boolean   @default(false)
  created_at DateTime  @default(now())
  created_by Int?
  updated_at DateTime  @updatedAt
  updated_by Int?
  deleted_at DateTime?
  deleted_by Int?

  user User @relation(fields: [user_id], references: [id])

  @@map("refresh_tokens")
}

enum SkuType {
  PACKAGE
  ADDON
}

enum ResourceType {
  CLINIC_ADDON
  USER_ADDON
}

model UserProfile {
  id            Int       @id @default(autoincrement())
  user_id       Int       @unique
  date_of_birth DateTime? @db.Date
  gender        String?
  address_line1 String?
  address_line2 String?
  city          String?
  utc_timezone  String?
  province      String?
  postal_code   String?
  country       String?
  clinic_name   String?
  photo_url     String?
  created_at    DateTime  @default(now())
  created_by    Int?
  updated_at    DateTime  @updatedAt
  updated_by    Int?
  deleted_at    DateTime?
  deleted_by    Int?

  user User @relation(fields: [user_id], references: [id])

  @@map("users_profile")
}

enum PackageTier {
  BASIC
  LITE
  MEDIUM
  PRO
  ENTERPRISE
}

model SkuBase {
  id                    Int          @id @default(autoincrement())
  sku_name              String
  sku_code              String       @unique
  sku_type              SkuType
  package_tier          PackageTier?
  rank                  Int          @default(0)
  billing_duration_days Int          @default(30)
  coin_cost             Decimal      @db.Decimal(10, 2)
  is_active             Boolean      @default(true)

  created_at DateTime  @default(now())
  created_by Int?
  updated_at DateTime  @updatedAt
  updated_by Int?
  deleted_at DateTime?
  deleted_by Int?

  benefits      SkuBenefit[]
  features      SkuFeature[]
  addons        SkuAddon[]
  subscriptions Subscription[]
  orders        Order[]
  switched_from PlanSwitch[]   @relation("OldSku")
  switched_to   PlanSwitch[]   @relation("NewSku")

  @@map("sku_base")
}

model SkuBenefit {
  id            Int       @id @default(autoincrement())
  sku_id        Int
  benefit_type  String // e.g., "clinic", "user"
  benefit_value String?
  max_usage     Int?
  is_unlimited  Boolean   @default(false) // when true, max_usage is ignored and the resource has no cap
  created_at    DateTime  @default(now())
  created_by    Int?
  updated_at    DateTime  @updatedAt
  updated_by    Int?
  deleted_at    DateTime?
  deleted_by    Int?

  sku SkuBase @relation(fields: [sku_id], references: [id])

  @@map("sku_benefits")
}

model SkuFeature {
  id           Int       @id @default(autoincrement())
  sku_id       Int
  display_name String
  feature      String
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  created_by   Int?
  updated_at   DateTime  @updatedAt
  updated_by   Int?
  deleted_at   DateTime?
  deleted_by   Int?

  sku SkuBase @relation(fields: [sku_id], references: [id])

  @@map("sku_features")
}

model SkuAddon {
  id            Int          @id @default(autoincrement())
  sku_id        Int
  resource_type ResourceType // e.g., CLINIC_ADDON, USER_ADDON
  display_name  String
  quota_value   Int
  is_unlimited  Boolean      @default(false) // when true, quota_value is ignored and the addon grants uncapped slots
  description   String?      @db.Text
  created_at    DateTime     @default(now())
  created_by    Int?
  updated_at    DateTime     @updatedAt
  updated_by    Int?
  deleted_at    DateTime?
  deleted_by    Int?

  sku SkuBase @relation(fields: [sku_id], references: [id])

  @@map("sku_addons")
}

// --------------------------------------------------------------------------
// Coin Currency & Wallet Management (Master Data)
// --------------------------------------------------------------------------

model CoinCurrency {
  id              Int       @id @default(autoincrement())
  currency_name   String
  currency_code   String    @unique // e.g., IDR, USD
  symbol          String
  conversion_rate Decimal   @db.Decimal(10, 4)
  is_active       Boolean   @default(true)
  effective_from  DateTime  @db.Date
  effective_until DateTime? @db.Date
  created_at      DateTime  @default(now())
  created_by      Int?
  updated_at      DateTime  @updatedAt
  updated_by      Int?
  deleted_at      DateTime?
  deleted_by      Int?

  bundles           CoinBundle[]
  coin_orders       CoinOrder[]
  coin_wallets      CoinWallet[]
  coin_transactions CoinTransaction[]

  @@map("coin_currencies")
}

model CoinBundle {
  id               Int       @id @default(autoincrement())
  bundle_name      String
  coin_amount      Int
  currency_id      Int
  price            Decimal   @db.Decimal(15, 2)
  discounted_price Decimal?  @db.Decimal(15, 2)
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())
  created_by       Int?
  updated_at       DateTime  @updatedAt
  updated_by       Int?
  deleted_at       DateTime?
  deleted_by       Int?

  currency    CoinCurrency @relation(fields: [currency_id], references: [id])
  coin_orders CoinOrder[]

  @@map("coin_bundles")
}

// --------------------------------------------------------------------------
// Tax and Payment Gateway Management (Master Data)
// --------------------------------------------------------------------------

enum FeeType {
  FIXED
  PERCENTAGE
}

model TaxConfig {
  id         Int       @id @default(autoincrement())
  tax_name   String
  tax_value  Decimal   @db.Decimal(15, 2)
  tax_type   FeeType
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  created_by Int?
  updated_at DateTime  @updatedAt
  updated_by Int?
  deleted_at DateTime?
  deleted_by Int?

  @@map("tax_config")
}

model PaymentMethod {
  id             Int       @id @default(autoincrement())
  name           String // e.g., Virtual Account Bank Mega, Credit Card, GoPay
  // Gateway-specific codes. A method is offered for a given gateway only when
  // its code for that gateway is set (non-null). e.g. bank_mega_code=megaqris,
  // midtrans_code=qris. Either may be null when a method is unsupported there.
  bank_mega_code String?   @unique
  midtrans_code  String?   @unique
  fee_type       FeeType // FIXED or PERCENTAGE
  fee_value      Decimal   @db.Decimal(15, 2)
  image_path     String?
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  created_by     Int?
  updated_at     DateTime  @updatedAt
  updated_by     Int?
  deleted_at     DateTime?
  deleted_by     Int?

  coin_orders       CoinOrder[]
  coin_transactions CoinTransaction[]

  @@map("payment_methods")
}

// --------------------------------------------------------------------------
// Coin Orders, Wallet & Transactions (Client)
// --------------------------------------------------------------------------

model CoinOrder {
  id                Int             @id @default(autoincrement())
  user_id           Int
  bundle_id         Int?
  is_custom_qty     Boolean         @default(false)
  coin_amount       Int
  payment_method_id Int?
  currency_id       Int
  coin_price        Decimal         @default(0) @db.Decimal(15, 2)
  tax_amount        Decimal         @default(0) @db.Decimal(15, 2)
  gateway_fee       Decimal         @default(0) @db.Decimal(15, 2)
  price_paid        Decimal         @db.Decimal(15, 2)
  status            CoinOrderStatus @default(PENDING)
  payment_gateway   String?
  snap_token        String?
  redirect_url      String?
  pg_order_id       String?         @unique
  pg_response_id    String?         @unique
  created_at        DateTime        @default(now())
  created_by        Int?
  updated_at        DateTime        @updatedAt
  updated_by        Int?
  deleted_at        DateTime?
  deleted_by        Int?

  user           User           @relation(fields: [user_id], references: [id])
  bundle         CoinBundle?    @relation(fields: [bundle_id], references: [id])
  payment_method PaymentMethod? @relation(fields: [payment_method_id], references: [id])
  currency       CoinCurrency   @relation(fields: [currency_id], references: [id])

  @@map("coin_orders")
}

model CoinWallet {
  id           Int       @id @default(autoincrement())
  user_id      Int       @unique
  balance      Decimal   @default(0) @db.Decimal(15, 2)
  currency_id  Int
  last_updated DateTime  @default(now())
  created_at   DateTime  @default(now())
  created_by   Int?
  updated_at   DateTime  @updatedAt
  updated_by   Int?
  deleted_at   DateTime?
  deleted_by   Int?

  user         User              @relation(fields: [user_id], references: [id])
  currency     CoinCurrency      @relation(fields: [currency_id], references: [id])
  transactions CoinTransaction[]

  @@map("coin_wallet")
}

model CoinTransaction {
  id                       Int                 @id @default(autoincrement())
  wallet_id                Int
  user_id                  Int
  type                     CoinTransactionType
  amount                   Decimal             @db.Decimal(15, 2)
  currency_id              Int
  conversion_rate_snapshot Decimal             @default(1) @db.Decimal(10, 4)
  ref_id                   Int?
  payment_method_id        Int?
  payment_channel          String? // raw gateway channel (e.g. bca_va, qris) for audit
  description              String?             @db.Text
  created_at               DateTime            @default(now())
  created_by               Int?
  updated_at               DateTime            @updatedAt
  updated_by               Int?
  deleted_at               DateTime?
  deleted_by               Int?

  wallet         CoinWallet     @relation(fields: [wallet_id], references: [id])
  user           User           @relation(fields: [user_id], references: [id])
  currency       CoinCurrency   @relation(fields: [currency_id], references: [id])
  payment_method PaymentMethod? @relation(fields: [payment_method_id], references: [id])

  @@map("coin_transactions")
}

// --------------------------------------------------------------------------
// Subscription Lifecycle (Client)
// --------------------------------------------------------------------------

model Subscription {
  id                    Int                @id @default(autoincrement())
  user_id               Int
  sku_id                Int
  sku_type              SkuType // PACKAGE or ADDON
  purchase_token        String?            @unique
  status                SubscriptionStatus @default(ACTIVE)
  auto_renew            Boolean            @default(false)
  current_billing_start DateTime?          @db.Date
  current_billing_end   DateTime?          @db.Date
  next_billing_date     DateTime?          @db.Date
  canceled_at           DateTime?
  expired_at            DateTime?
  created_at            DateTime           @default(now())
  created_by            Int?
  updated_at            DateTime           @updatedAt
  updated_by            Int?
  deleted_at            DateTime?
  deleted_by            Int?

  user            User                @relation(fields: [user_id], references: [id])
  sku             SkuBase             @relation(fields: [sku_id], references: [id])
  quotas          SubscriptionQuota[]
  addon_slot_maps AddonSlotMap[]
  orders          Order[]
  events          SubscriptionEvent[]
  billing_cycles  BillingCycle[]
  switches_from   PlanSwitch[]        @relation("OldSubscription")
  switches_to     PlanSwitch[]        @relation("NewSubscription")

  @@map("subscriptions")
}

model SubscriptionQuota {
  id                      Int       @id @default(autoincrement())
  user_id                 Int
  package_subscription_id Int
  resource_type           String // clinic, user
  total_quota             Int
  is_unlimited            Boolean   @default(false) // when true, total_quota is ignored and assignment is uncapped
  used_quota              Int       @default(0)
  last_recalculated_at    DateTime?
  created_at              DateTime  @default(now())
  created_by              Int?
  updated_at              DateTime  @updatedAt
  updated_by              Int?
  deleted_at              DateTime?
  deleted_by              Int?

  user         User         @relation(fields: [user_id], references: [id])
  subscription Subscription @relation(fields: [package_subscription_id], references: [id])

  @@map("subscription_quotas")
}

model AddonSlotMap {
  id                    Int       @id @default(autoincrement())
  addon_subscription_id Int
  ref_type              String // clinic, op_user
  ref_id                Int
  created_at            DateTime  @default(now())
  created_by            Int?
  updated_at            DateTime  @updatedAt
  updated_by            Int?
  deleted_at            DateTime?
  deleted_by            Int?

  subscription Subscription @relation(fields: [addon_subscription_id], references: [id])

  // Slots are attributed to the specific source subscription that provided them
  // (package first, then add-ons oldest-first). These indexes back the expiry
  // revocation sweep (by source) and the release lookup (by ref).
  @@index([addon_subscription_id, deleted_at])
  @@index([ref_id, ref_type])
  @@map("addon_slot_map")
}

model Order {
  id              Int       @id @default(autoincrement())
  subscription_id Int
  user_id         Int
  sku_id          Int
  order_number    String    @unique
  renewal_index   Int       @default(0)
  coin_amount     Int
  status          String    @default("COMPLETED")
  promo_id        Int?
  created_at      DateTime  @default(now())
  created_by      Int?
  updated_at      DateTime  @updatedAt
  updated_by      Int?
  deleted_at      DateTime?
  deleted_by      Int?

  subscription   Subscription   @relation(fields: [subscription_id], references: [id])
  user           User           @relation(fields: [user_id], references: [id])
  sku            SkuBase        @relation(fields: [sku_id], references: [id])
  billing_cycles BillingCycle[]

  @@map("orders")
}

model SubscriptionEvent {
  id              Int                   @id @default(autoincrement())
  subscription_id Int
  billing_id      Int?
  event_type      SubscriptionEventType
  metadata        Json?
  created_at      DateTime              @default(now())
  created_by      Int?
  updated_at      DateTime              @updatedAt
  updated_by      Int?
  deleted_at      DateTime?
  deleted_by      Int?

  subscription  Subscription  @relation(fields: [subscription_id], references: [id])
  billing_cycle BillingCycle? @relation(fields: [billing_id], references: [id])

  @@map("subscription_events")
}

model BillingCycle {
  id              Int                @id @default(autoincrement())
  subscription_id Int
  order_id        Int?
  cycle_start     DateTime
  cycle_end       DateTime
  status          BillingCycleStatus @default(PENDING)
  created_at      DateTime           @default(now())
  created_by      Int?
  updated_at      DateTime           @updatedAt
  updated_by      Int?
  deleted_at      DateTime?
  deleted_by      Int?

  subscription Subscription        @relation(fields: [subscription_id], references: [id])
  order        Order?              @relation(fields: [order_id], references: [id])
  events       SubscriptionEvent[]

  @@map("billing_cycles")
}

model PlanSwitch {
  id                  Int              @id @default(autoincrement())
  user_id             Int
  old_subscription_id Int
  new_subscription_id Int
  old_sku_id          Int
  new_sku_id          Int
  switch_type         PlanSwitchType
  prorated_amount     Decimal          @db.Decimal(15, 2)
  status              PlanSwitchStatus @default(PENDING)
  created_at          DateTime         @default(now())
  created_by          Int?
  updated_at          DateTime         @updatedAt
  updated_by          Int?
  deleted_at          DateTime?
  deleted_by          Int?

  old_subscription Subscription @relation("OldSubscription", fields: [old_subscription_id], references: [id])
  new_subscription Subscription @relation("NewSubscription", fields: [new_subscription_id], references: [id])
  old_sku          SkuBase      @relation("OldSku", fields: [old_sku_id], references: [id])
  new_sku          SkuBase      @relation("NewSku", fields: [new_sku_id], references: [id])

  @@map("plan_switches")
}

model DentalAd {
  id         Int       @id @default(autoincrement())
  name       String
  category   String
  image_path String
  created_at DateTime  @default(now())
  created_by Int?
  updated_at DateTime  @updatedAt
  updated_by Int?
  deleted_at DateTime?
  deleted_by Int?

  @@map("dental_ads")
}

// --------------------------------------------------------------------------
// Webhook Outbox for Domain 2 Integration
// --------------------------------------------------------------------------

enum WebhookOutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model WebhookOutbox {
  id              Int                 @id @default(autoincrement())
  idempotency_key String              @unique
  event_type      String // e.g. "subscription.created", "addon.expired"
  company_id      Int
  payload         Json
  status          WebhookOutboxStatus @default(PENDING)
  attempts        Int                 @default(0)
  max_attempts    Int                 @default(6)
  next_attempt_at DateTime?
  last_error      String?             @db.Text
  sent_at         DateTime?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt

  @@index([status, next_attempt_at])
  @@map("webhook_outbox")
}

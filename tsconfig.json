{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@config/*": [
        "./src/config/*"
      ],
      "@middlewares/*": [
        "./src/middlewares/*"
      ],
      "@controllers/*": [
        "./src/controllers/*"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ]
    },
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "esnext",
    "types": [
      "node"
    ],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "prisma",
    "src/**/__tests__",
    "src/**/*.test.ts"
  ],
  "ts-node": {
    "compilerOptions": {
      "types": [
        "node",
        "jest"
      ]
    }
  }
}
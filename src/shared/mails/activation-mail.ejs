<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Activate Your Account</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&family=Barlow:wght@900&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #F4F6F8;
      font-family: 'Public Sans', Helvetica, Arial, sans-serif;
      color: #212B36;
      padding: 40px 16px;
      -webkit-font-smoothing: antialiased;
    }

    .wrapper {
      max-width: 560px;
      margin: 0 auto;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 32px;
    }

    .logo {
      display: inline-block;
      font-family: 'Barlow', Helvetica, Arial, sans-serif;
      font-weight: 900;
      font-size: 24px;
      color: #212B36;
      letter-spacing: -0.5px;
    }

    .logo span {
      color: #00AB55;
    }

    /* Card */
    .card {
      background: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 0 2px 0 rgba(145, 158, 171, 0.2), 0 12px 24px -4px rgba(145, 158, 171, 0.12);
    }

    .card-accent {
      height: 4px;
      background: linear-gradient(90deg, #007B55 0%, #00AB55 50%, #5BE584 100%);
    }

    .card-body {
      padding: 40px 40px 36px;
    }

    /* Greeting */
    .greeting {
      font-size: 24px;
      font-weight: 800;
      color: #212B36;
      margin-bottom: 12px;
      line-height: 1.3;
    }

    .greeting .name {
      color: #00AB55;
    }

    .subtext {
      font-size: 15px;
      color: #637381;
      line-height: 1.7;
      margin-bottom: 32px;
    }

    /* Code block */
    .code-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #919EAB;
      margin-bottom: 10px;
    }

    .code-container {
      background: #F4F6F8;
      border: 1px solid #DFE3E8;
      border-radius: 12px;
      padding: 24px;
      text-align: center;
      margin-bottom: 28px;
    }

    .activation-code {
      font-family: 'Public Sans', Helvetica, Arial, sans-serif;
      font-size: 38px;
      font-weight: 800;
      letter-spacing: 10px;
      color: #212B36;
    }

    .code-expiry {
      margin-top: 10px;
      font-size: 12px;
      color: #637381;
    }

    .code-expiry strong {
      color: #00AB55;
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid #DFE3E8;
      margin: 28px 0;
    }

    /* Warning */
    .warning {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      background: #FFF5CC;
      border: 1px solid #FFD666;
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 28px;
    }

    .warning-icon {
      font-size: 16px;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .warning-text {
      font-size: 13px;
      color: #7A4100;
      line-height: 1.6;
    }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 28px;
    }

    .footer p {
      font-size: 12px;
      color: #919EAB;
      line-height: 1.8;
    }

    .footer a {
      color: #00AB55;
      text-decoration: none;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    .footer .company {
      margin-top: 16px;
      font-size: 11px;
      color: #C4CDD5;
    }

    @media (max-width: 480px) {
      .card-body {
        padding: 28px 24px;
      }

      .activation-code {
        font-size: 28px;
        letter-spacing: 6px;
      }

      .greeting {
        font-size: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header / Logo -->
    <div class="header">
      <div class="logo">Idental <span>x Artoo Pay</span></div>
    </div>

    <!-- Main Card -->
    <div class="card">
      <div class="card-accent"></div>
      <div class="card-body">

        <h1 class="greeting">
          Hey, <span class="name"><%= user.name %></span> 👋
        </h1>
        <p class="subtext">
          Thanks for signing up! To complete your registration and activate your account,
          use the verification code below.
        </p>

        <p class="code-label">Your Activation Code</p>
        <div class="code-container">
          <div class="activation-code"><%= activationCode %></div>
          <p class="code-expiry">Expires in <strong>10 minutes</strong></p>
        </div>

        <div class="warning">
          <span class="warning-icon">⚠️</span>
          <p class="warning-text">
            Never share this code with anyone. Our team will <strong>never</strong> ask for your activation code.
          </p>
        </div>

        <hr class="divider" />

        <p style="font-size: 13px; color: #919EAB; line-height: 1.7;">
          If you didn't create an account, you can safely ignore this email.
          Someone may have entered your email address by mistake.
        </p>

      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>
        Need help? <a href="mailto:support@idental.id">Contact Support</a>
      </p>
      <p class="company">© <%= new Date().getFullYear() %> Idental x Artoo Pay. · All rights reserved.</p>
    </div>

  </div>
</body>
</html>

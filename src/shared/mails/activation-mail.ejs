<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Activate Your Account</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=JetBrains+Mono:wght@500;700&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #f9fafb;
      font-family: 'Sora', sans-serif;
      color: #1f2937;
      padding: 40px 16px;
    }

    .wrapper {
      max-width: 560px;
      margin: 0 auto;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 32px;
    }

    .logo {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700;
      font-size: 22px;
      color: #111827;
      letter-spacing: -0.5px;
    }

    .logo span {
      color: #22c55e;
    }

    /* Card */
    .card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }

    .card-accent {
      height: 4px;
      background: linear-gradient(90deg, #22c55e 0%, #4ade80 50%, #86efac 100%);
    }

    .card-body {
      padding: 40px 40px 36px;
    }

    /* Greeting */
    .greeting {
      font-size: 24px;
      font-weight: 700;
      color: #111827;
      margin-bottom: 12px;
      line-height: 1.3;
    }

    .greeting .name {
      color: #4ade80;
    }

    .subtext {
      font-size: 14px;
      color: #4b5563;
      line-height: 1.7;
      margin-bottom: 32px;
    }

    /* Code block */
    .code-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #6b7280;
      margin-bottom: 10px;
    }

    .code-container {
      background: #f3f4f6;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 24px;
      text-align: center;
      margin-bottom: 28px;
      position: relative;
    }

    .code-container::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 12px;
      background: radial-gradient(ellipse at center, rgba(34, 197, 94, 0.06) 0%, transparent 70%);
      pointer-events: none;
    }

    .activation-code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 38px;
      font-weight: 700;
      letter-spacing: 10px;
      color: #111827;
      text-shadow: 0 0 24px rgba(34, 197, 94, 0.2);
    }

    .code-expiry {
      margin-top: 10px;
      font-size: 12px;
      color: #6b7280;
    }

    .code-expiry strong {
      color: #4ade80;
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 28px 0;
    }

    /* Warning */
    .warning {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      background: #fef3c7;
      border: 1px solid #fde68a;
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 28px;
    }

    .warning-icon {
      font-size: 16px;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .warning-text {
      font-size: 13px;
      color: #92400e;
      line-height: 1.6;
    }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 28px;
    }

    .footer p {
      font-size: 12px;
      color: #6b7280;
      line-height: 1.8;
    }

    .footer a {
      color: #22c55e;
      text-decoration: none;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    .footer .company {
      margin-top: 16px;
      font-size: 11px;
      color: #9ca3af;
    }

    @media (max-width: 480px) {
      .card-body {
        padding: 28px 24px;
      }

      .activation-code {
        font-size: 28px;
        letter-spacing: 6px;
      }

      .greeting {
        font-size: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header / Logo -->
    <div class="header">
      <div class="logo">Idental <span>x Artoo Pay</span></div>
    </div>

    <!-- Main Card -->
    <div class="card">
      <div class="card-accent"></div>
      <div class="card-body">

        <h1 class="greeting">
          Hey, <span class="name"><%= user.name %></span> 👋
        </h1>
        <p class="subtext">
          Thanks for signing up! To complete your registration and activate your account,
          use the verification code below.
        </p>

        <p class="code-label">Your Activation Code</p>
        <div class="code-container">
          <div class="activation-code"><%= activationCode %></div>
          <p class="code-expiry">Expires in <strong>10 minutes</strong></p>
        </div>

        <div class="warning">
          <span class="warning-icon">⚠️</span>
          <p class="warning-text">
            Never share this code with anyone. Our team will <strong>never</strong> ask for your activation code.
          </p>
        </div>

        <hr class="divider" />

        <p style="font-size: 13px; color: #6b7280; line-height: 1.7;">
          If you didn't create an account, you can safely ignore this email.
          Someone may have entered your email address by mistake.
        </p>

      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>
        Need help? <a href="mailto:support@idental.id">Contact Support</a>
      </p>
      <p class="company">© <%= new Date().getFullYear() %> Idental x Artoo Pay. · All rights reserved.</p>
    </div>

  </div>
</body>
</html>

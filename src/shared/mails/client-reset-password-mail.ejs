<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Your Password</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=JetBrains+Mono:wght@500;700&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #f9fafb;
      font-family: 'Sora', sans-serif;
      color: #1f2937;
      padding: 40px 16px;
    }

    .wrapper {
      max-width: 560px;
      margin: 0 auto;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 32px;
    }

    .logo {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700;
      font-size: 22px;
      color: #111827;
      letter-spacing: -0.5px;
    }

    .logo span {
      color: #22c55e;
    }

    /* Card */
    .card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }

    .card-accent {
      height: 4px;
      background: linear-gradient(90deg, #22c55e 0%, #4ade80 50%, #60a5fa 100%);
    }

    .card-body {
      padding: 40px 40px 36px;
    }

    /* Greeting */
    .greeting {
      font-size: 24px;
      font-weight: 700;
      color: #111827;
      margin-bottom: 12px;
      line-height: 1.3;
    }

    .greeting .name {
      color: #4ade80;
    }

    .subtext {
      font-size: 14px;
      color: #4b5563;
      line-height: 1.7;
      margin-bottom: 32px;
    }

    /* CTA Button */
    .cta-container {
      text-align: center;
      margin-bottom: 28px;
    }

    .cta-button {
      display: inline-block;
      padding: 16px 48px;
      background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
      color: #ffffff;
      font-family: 'Sora', sans-serif;
      font-size: 16px;
      font-weight: 600;
      text-decoration: none;
      border-radius: 12px;
      letter-spacing: 0.5px;
      transition: transform 0.2s;
    }

    .cta-button:hover {
      transform: translateY(-2px);
    }

    .link-fallback {
      margin-top: 16px;
      font-size: 12px;
      color: #6b7280;
      word-break: break-all;
    }

    .link-fallback a {
      color: #22c55e;
      text-decoration: none;
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 28px 0;
    }

    /* Warning */
    .warning {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      background: #fef3c7;
      border: 1px solid #fde68a;
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 28px;
    }

    .warning-icon {
      font-size: 16px;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .warning-text {
      font-size: 13px;
      color: #92400e;
      line-height: 1.6;
    }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 28px;
    }

    .footer p {
      font-size: 12px;
      color: #6b7280;
      line-height: 1.8;
    }

    .footer a {
      color: #22c55e;
      text-decoration: none;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    .footer .company {
      margin-top: 16px;
      font-size: 11px;
      color: #9ca3af;
    }

    @media (max-width: 480px) {
      .card-body {
        padding: 28px 24px;
      }

      .greeting {
        font-size: 20px;
      }

      .cta-button {
        padding: 14px 32px;
        font-size: 14px;
      }
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header / Logo -->
    <div class="header">
      <div class="logo">Idental <span>x Artoo Pay</span></div>
    </div>

    <!-- Main Card -->
    <div class="card">
      <div class="card-accent"></div>
      <div class="card-body">

        <h1 class="greeting">
          Hello, <span class="name"><%= user.name %></span> 🔒
        </h1>
        <p class="subtext">
          We received a request to reset your password. Please click the button below to set a new password for your account.
        </p>

        <div class="cta-container">
          <a href="<%= resetLink %>" class="cta-button" target="_blank">
            Reset Password
          </a>
          <p class="link-fallback">
            Or copy and paste this link into your browser:<br/>
            <a href="<%= resetLink %>"><%= resetLink %></a>
          </p>
        </div>

        <div class="warning">
          <span class="warning-icon">⚠️</span>
          <p class="warning-text">
            This reset link expires in <strong>1 hour</strong>. If you didn't request a password reset,
            you can safely ignore this email. Your password will remain unchanged.
          </p>
        </div>

        <hr class="divider" />

        <p style="font-size: 13px; color: #6b7280; line-height: 1.7;">
          If you're having trouble clicking the button, copy and paste the URL above
          into your web browser.
        </p>

      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>
        Need help? <a href="mailto:support@idental.id">Contact Support</a>
      </p>
      <p class="company">© <%= new Date().getFullYear() %> Idental x Artoo Pay. · All rights reserved.</p>
    </div>

  </div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Payment Successful</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&family=Barlow:wght@900&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #FFFFFF;
      font-family: 'Public Sans', Helvetica, Arial, sans-serif;
      color: #212B36;
      padding: 40px 16px;
      -webkit-font-smoothing: antialiased;
    }

    .wrapper {
      max-width: 560px;
      margin: 0 auto;
    }

    /* Card */
    .card {
      background: #ffffff;
      border: 1px solid #ECEFF1;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 0 2px 0 rgba(145, 158, 171, 0.2), 0 12px 24px -4px rgba(145, 158, 171, 0.12);
    }

    /* Header / Logo */
    .card-header {
      text-align: center;
      padding: 28px 40px;
      border-bottom: 1px solid #ECEFF1;
    }

    .logo {
      display: inline-block;
      font-family: 'Barlow', Helvetica, Arial, sans-serif;
      font-weight: 900;
      font-size: 24px;
      color: #212B36;
      letter-spacing: -0.5px;
    }

    .card-body {
      padding: 36px 40px;
    }

    /* Success status */
    .status {
      text-align: center;
      margin-bottom: 28px;
    }

    .status-check {
      display: inline-block;
      width: 64px;
      height: 64px;
      line-height: 64px;
      border-radius: 50%;
      background: #212B36;
      color: #ffffff;
      font-size: 32px;
      font-weight: 700;
      text-align: center;
      margin-bottom: 16px;
    }

    .status-title {
      font-size: 24px;
      font-weight: 800;
      color: #212B36;
      margin-bottom: 8px;
      line-height: 1.3;
    }

    .status-subtext {
      font-size: 15px;
      color: #637381;
      line-height: 1.7;
    }

    /* Hero panel (type-specific highlight) */
    .hero {
      background: #F4F6F8;
      border: 1px solid #DFE3E8;
      border-radius: 12px;
      padding: 24px;
      text-align: center;
      margin-bottom: 28px;
    }

    .hero-amount {
      font-size: 34px;
      font-weight: 800;
      color: #212B36;
      letter-spacing: -0.5px;
      line-height: 1.2;
    }

    .hero-name {
      font-size: 22px;
      font-weight: 800;
      color: #212B36;
      line-height: 1.3;
    }

    .hero-label {
      margin-top: 8px;
      font-size: 13px;
      color: #637381;
      line-height: 1.6;
    }

    .hero-meta {
      margin-top: 12px;
      display: inline-block;
      padding: 5px 12px;
      background: #ffffff;
      border: 1px solid #DFE3E8;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 600;
      color: #454F5B;
    }

    /* Order summary */
    .summary-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #919EAB;
      margin-bottom: 12px;
    }

    .summary {
      border: 1px solid #DFE3E8;
      border-radius: 12px;
      padding: 8px 20px;
      margin-bottom: 28px;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 16px;
      padding: 12px 0;
      border-bottom: 1px solid #F0F1F3;
    }

    .summary-row:last-child {
      border-bottom: none;
    }

    .summary-row .key {
      font-size: 13px;
      color: #637381;
    }

    .summary-row .val {
      font-size: 13px;
      font-weight: 600;
      color: #212B36;
      text-align: right;
      word-break: break-word;
    }

    .summary-total {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 16px;
      padding: 16px 0 12px;
      border-top: 2px solid #DFE3E8;
    }

    .summary-total .key {
      font-size: 14px;
      font-weight: 700;
      color: #212B36;
    }

    .summary-total .val {
      font-size: 20px;
      font-weight: 800;
      color: #212B36;
    }

    /* CTA Button */
    .cta-container {
      text-align: center;
      margin-bottom: 28px;
    }

    .cta-button {
      display: inline-block;
      padding: 15px 48px;
      background: #212B36;
      color: #ffffff;
      font-family: 'Public Sans', Helvetica, Arial, sans-serif;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 8px;
      letter-spacing: 0.2px;
      box-shadow: 0 8px 16px 0 rgba(33, 43, 54, 0.24);
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid #DFE3E8;
      margin: 28px 0;
    }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 28px;
    }

    .footer p {
      font-size: 12px;
      color: #919EAB;
      line-height: 1.8;
    }

    .footer a {
      color: #212B36;
      text-decoration: underline;
    }

    .footer .company {
      margin-top: 16px;
      font-size: 11px;
      color: #C4CDD5;
    }

    @media (max-width: 480px) {
      .card-header {
        padding: 24px;
      }

      .card-body {
        padding: 28px 24px;
      }

      .status-title {
        font-size: 20px;
      }

      .hero-amount {
        font-size: 28px;
      }

      .cta-button {
        padding: 14px 32px;
        font-size: 14px;
      }
    }
  </style>
</head>
<%
  // Defaults & helpers — keep all formatting in one place so the markup stays clean.
  const symbol = purchase.currencySymbol || 'Rp';
  const money = (n) => `${symbol} ${Number(n || 0).toLocaleString('id-ID')}`;
  const num = (n) => Number(n || 0).toLocaleString('id-ID');
  const purchaseDate = purchase.purchaseDate
    || new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
  const lineItems = purchase.lineItems || [];
%>
<body>
  <div class="wrapper">

    <!-- Main Card -->
    <div class="card">

      <!-- Header / Logo -->
      <div class="card-header">
        <div class="logo">Idental</div>
      </div>

      <div class="card-body">

        <!-- Success status -->
        <div class="status">
          <div class="status-check">&#10003;</div>
          <h1 class="status-title">Payment Successful</h1>
          <p class="status-subtext">
            Thanks for your purchase, <strong><%= user.name %></strong>. Your payment has been confirmed
            and your order is now complete.
          </p>
        </div>

        <!-- Type-specific hero -->
        <div class="hero">
          <% if (purchase.type === 'coin') { %>
            <div class="hero-amount">+<%= num(purchase.coinAmount) %> Coins</div>
            <p class="hero-label">added to your wallet</p>
            <% if (purchase.newBalance !== undefined && purchase.newBalance !== null) { %>
              <span class="hero-meta">New balance: <%= num(purchase.newBalance) %> coins</span>
            <% } %>
          <% } else if (purchase.type === 'plan') { %>
            <div class="hero-name"><%= purchase.planName %></div>
            <% if (purchase.planPeriod) { %>
              <p class="hero-label"><%= purchase.planPeriod %></p>
            <% } %>
            <% if (purchase.validUntil) { %>
              <span class="hero-meta">Active until <%= purchase.validUntil %></span>
            <% } %>
          <% } else if (purchase.type === 'addon') { %>
            <div class="hero-name"><%= purchase.addonName %></div>
            <p class="hero-label">added to your subscription</p>
            <% if (purchase.addonQty !== undefined && purchase.addonQty !== null) { %>
              <span class="hero-meta"><%= num(purchase.addonQty) %> slot<%= Number(purchase.addonQty) > 1 ? 's' : '' %></span>
            <% } %>
          <% } %>
        </div>

        <!-- Order summary -->
        <p class="summary-label">Order Summary</p>
        <div class="summary">
          <div class="summary-row">
            <span class="key">Order ID</span>
            <span class="val"><%= purchase.orderId %></span>
          </div>
          <div class="summary-row">
            <span class="key">Date</span>
            <span class="val"><%= purchaseDate %></span>
          </div>
          <% if (purchase.paymentMethod) { %>
            <div class="summary-row">
              <span class="key">Payment Method</span>
              <span class="val"><%= purchase.paymentMethod %></span>
            </div>
          <% } %>
          <% lineItems.forEach(function (item) { %>
            <div class="summary-row">
              <span class="key"><%= item.label %></span>
              <span class="val"><%= money(item.amount) %></span>
            </div>
          <% }); %>
          <div class="summary-total">
            <span class="key">Total Paid</span>
            <span class="val"><%= money(purchase.totalPaid) %></span>
          </div>
        </div>

        <% if (purchase.ctaUrl) { %>
          <div class="cta-container">
            <a href="<%= purchase.ctaUrl %>" class="cta-button" target="_blank">
              <%= purchase.ctaLabel || 'View My Account' %>
            </a>
          </div>
        <% } %>

        <hr class="divider" />

        <p style="font-size: 13px; color: #919EAB; line-height: 1.7;">
          This email is your receipt. If you don't recognise this purchase or need help,
          please contact our support team right away.
        </p>

      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>
        Need help? <a href="mailto:support@idental.id">Contact Support</a>
      </p>
      <p class="company">© <%= new Date().getFullYear() %> Idental · All rights reserved.</p>
    </div>

  </div>
</body>
</html>

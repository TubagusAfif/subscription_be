<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Subscription Expiry Notice</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&family=Barlow:wght@900&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #FFFFFF;
      font-family: 'Public Sans', Helvetica, Arial, sans-serif;
      color: #212B36;
      padding: 40px 16px;
      -webkit-font-smoothing: antialiased;
    }

    .wrapper {
      max-width: 560px;
      margin: 0 auto;
    }

    /* Card */
    .card {
      background: #ffffff;
      border: 1px solid #ECEFF1;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 0 2px 0 rgba(145, 158, 171, 0.2), 0 12px 24px -4px rgba(145, 158, 171, 0.12);
    }

    /* Header / Logo */
    .card-header {
      text-align: center;
      padding: 28px 40px;
      border-bottom: 1px solid #ECEFF1;
    }

    .logo {
      display: inline-block;
      font-family: 'Barlow', Helvetica, Arial, sans-serif;
      font-weight: 900;
      font-size: 24px;
      color: #212B36;
      letter-spacing: -0.5px;
    }

    .card-body {
      padding: 36px 40px;
    }

    /* Status badge */
    .badge {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 16px;
    }

    .badge-info {
      background: #FFF5CC;
      color: #7A4100;
    }

    .badge-danger {
      background: #FFE9D5;
      color: #7A0916;
    }

    /* Greeting */
    .greeting {
      font-size: 24px;
      font-weight: 800;
      color: #212B36;
      margin-bottom: 12px;
      line-height: 1.3;
    }

    .greeting .name {
      color: #212B36;
    }

    .subtext {
      font-size: 15px;
      color: #637381;
      line-height: 1.7;
      margin-bottom: 16px;
    }

    .subtext strong {
      color: #212B36;
      font-weight: 700;
    }

    .highlight {
      color: #212B36;
      font-weight: 700;
    }

    .highlight-danger {
      color: #B71D18;
      font-weight: 700;
    }

    /* Info panel */
    .panel {
      background: #F4F6F8;
      border: 1px solid #DFE3E8;
      border-radius: 12px;
      padding: 20px 24px;
      margin: 24px 0;
    }

    .panel-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #919EAB;
      margin-bottom: 6px;
    }

    .panel-value {
      font-size: 18px;
      font-weight: 700;
      color: #212B36;
    }

    /* CTA Button */
    .cta-container {
      text-align: center;
      margin: 28px 0 8px;
    }

    .cta-button {
      display: inline-block;
      padding: 15px 48px;
      background: #212B36;
      color: #ffffff;
      font-family: 'Public Sans', Helvetica, Arial, sans-serif;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 8px;
      letter-spacing: 0.2px;
      box-shadow: 0 8px 16px 0 rgba(33, 43, 54, 0.24);
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid #DFE3E8;
      margin: 28px 0;
    }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 28px;
    }

    .footer p {
      font-size: 12px;
      color: #919EAB;
      line-height: 1.8;
    }

    .footer a {
      color: #212B36;
      text-decoration: underline;
    }

    .footer .company {
      margin-top: 16px;
      font-size: 11px;
      color: #C4CDD5;
    }

    @media (max-width: 480px) {
      .card-header {
        padding: 24px;
      }

      .card-body {
        padding: 28px 24px;
      }

      .greeting {
        font-size: 20px;
      }

      .cta-button {
        padding: 14px 32px;
        font-size: 14px;
      }
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Main Card -->
    <div class="card">

      <!-- Header / Logo -->
      <div class="card-header">
        <div class="logo">Idental</div>
      </div>

      <div class="card-body">

        <% if (daysBefore === 0) { %>
          <span class="badge badge-info">Expires Today</span>
        <% } else if (daysBefore === -1) { %>
          <span class="badge badge-info">Grace Period</span>
        <% } else if (daysBefore === -7) { %>
          <span class="badge badge-danger">Access Restricted</span>
        <% } else { %>
          <span class="badge badge-info">Renewal Reminder</span>
        <% } %>

        <h1 class="greeting">
          Hello, <span class="name"><%= user.name %></span>
        </h1>

        <div class="panel">
          <p class="panel-label">Subscription</p>
          <p class="panel-value"><%= skuName %></p>
        </div>

        <% if (daysBefore === 0) { %>
          <p class="subtext">
            This is a reminder that your subscription for <strong><%= skuName %></strong>
            expires <span class="highlight-danger">today</span>.
          </p>
          <p class="subtext">
            Please renew your subscription to continue enjoying our services without interruption.
          </p>
        <% } else if (daysBefore === -1) { %>
          <p class="subtext">
            Your subscription for <strong><%= skuName %></strong> expired <strong>yesterday</strong>.
          </p>
          <p class="subtext">
            You have entered a <span class="highlight">7-day grace period</span> where your services
            will continue to work normally. Please renew immediately to avoid interruption.
          </p>
        <% } else if (daysBefore === -7) { %>
          <p class="subtext">
            Your 7-day grace period for <strong><%= skuName %></strong> has ended.
          </p>
          <p class="subtext">
            Your services have now been <span class="highlight-danger">restricted</span>.
            Please renew to reactivate your access.
          </p>
        <% } else { %>
          <p class="subtext">
            This is a reminder that your subscription for <strong><%= skuName %></strong> will expire in
            <span class="highlight"><%= daysBefore %> day<%= daysBefore > 1 ? 's' : '' %></span>.
          </p>
          <p class="subtext">
            Please renew your subscription before the expiry date to avoid any service interruptions.
          </p>
        <% } %>

        <hr class="divider" />

        <p style="font-size: 13px; color: #919EAB; line-height: 1.7;">
          If you have already renewed, please ignore this email.
        </p>

      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>
        Need help? <a href="mailto:support@idental.id">Contact Support</a>
      </p>
      <p class="company">© <%= new Date().getFullYear() %> Idental · All rights reserved.</p>
    </div>

  </div>
</body>
</html>
